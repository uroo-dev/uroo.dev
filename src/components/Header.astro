---
import LanguageToggle from './LanguageToggle.astro';
---

<div id="header-island" class="header-island">
  <a href="/" class="header-island-logo">
    <span>U</span> UROO.DEV
  </a>
  <nav class="header-island-nav">
    <a href="/">Home</a>
    <a href="/services">Solutions</a>
    <a href="/portfolio">Work</a>
    <a href="/case-studies">Case Studies</a>
    <a href="/about">About</a>
    <a href="/contact">Contact</a>
  </nav>
  <div class="flex items-center gap-2">
    <LanguageToggle />
    <a href="/contact" class="header-island-cta">Free Consultation</a>
    <button id="island-menu-btn" class="header-island-btn">
      <svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
    </button>
  </div>
</div>

<div id="mobile-island-menu" class="hidden fixed top-20 left-1/2 -translate-x-1/2 z-40 w-[calc(100%-32px)] max-w-sm bg-black/90 backdrop-blur-2xl border border-white/10 rounded-2xl p-6">
  <div class="flex flex-col gap-5">
    <a href="/" class="text-white/70 hover:text-white text-sm no-underline transition-colors">Home</a>
    <a href="/services" class="text-white/70 hover:text-white text-sm no-underline transition-colors">Solutions</a>
    <a href="/portfolio" class="text-white/70 hover:text-white text-sm no-underline transition-colors">Work</a>
    <a href="/case-studies" class="text-white/70 hover:text-white text-sm no-underline transition-colors">Case Studies</a>
    <a href="/about" class="text-white/70 hover:text-white text-sm no-underline transition-colors">About</a>
    <a href="/contact" class="text-white/70 hover:text-white text-sm no-underline transition-colors">Contact</a>
    <div class="pt-4 border-t border-white/10">
      <a href="/contact" class="block text-center text-sm text-black bg-white px-6 py-3 rounded-full font-medium no-underline">Get Free Consultation</a>
    </div>
  </div>
</div>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const island = document.getElementById('header-island');
    const menuBtn = document.getElementById('island-menu-btn');
    const mobileMenu = document.getElementById('mobile-island-menu');
    let lastScroll = 0;

    const toggleIsland = () => {
      const sy = window.scrollY;
      if (sy > 400) {
        island.classList.add('visible');
      } else {
        island.classList.remove('visible');
        mobileMenu.classList.add('hidden');
      }
      lastScroll = sy;
    };

    window.addEventListener('scroll', toggleIsland, { passive: true });
    toggleIsland();

    if (menuBtn && mobileMenu) {
      menuBtn.addEventListener('click', () => {
        mobileMenu.classList.toggle('hidden');
      });
      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => {
          mobileMenu.classList.add('hidden');
        });
      });
      document.addEventListener('click', (e) => {
        if (!menuBtn.contains(e.target) && !mobileMenu.contains(e.target)) {
          mobileMenu.classList.add('hidden');
        }
      });
    }
  });
</script>
