---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Blog">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label">Blog</p>
        <h1 class="section-title-main section-title-main-lg">Insights & Articles</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl mx-auto">Thoughts on software development, technology, and building digital products.</p>
    </div>
  </section>
  <section class="section-gap bg-carbon-canvas text-center">
    <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke">Coming soon. Stay tuned.</p>
  </section>
</Layout>
