---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Case Studies">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label">Case Studies</p>
        <h1 class="section-title-main section-title-main-lg">Problem → Solution → Result</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl mx-auto">Real projects, real challenges, real impact.</p>
    </div>
  </section>

  <section class="section-gap bg-carbon-canvas">
    <div class="page-container">
      <div class="space-y-12 max-w-4xl mx-auto">
        <div class="review-card">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray mb-2 uppercase">Inventory Management</p>
              <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-4">Gudangku Native</h2>
              <p class="review-card-quote text-sm mb-4">Inventory management system for a growing retail business struggling with manual stock tracking and frequent stockouts.</p>
              <a href="/case-studies/gudangku-native" class="font-circularxx font-medium text-body-sm tracking-body-sm text-bone-white underline underline-offset-4 hover:opacity-70 transition-opacity">Read Case Study</a>
            </div>
            <div class="aspect-video bg-ash-veil/10 flex items-center justify-center" style="border-radius: 17.6px;">
              <svg class="w-16 h-16 text-iron-gray/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
            </div>
          </div>
        </div>
        <div class="review-card">
          <div class="grid md:grid-cols-2 gap-8 items-start">
            <div>
              <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray mb-2 uppercase">Point of Sale</p>
              <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-4">Kasir Dimas</h2>
              <p class="review-card-quote text-sm mb-4">A modern POS system designed to replace outdated cash registers with a web-based, multi-user platform.</p>
              <a href="/case-studies/kasir-dimas" class="font-circularxx font-medium text-body-sm tracking-body-sm text-bone-white underline underline-offset-4 hover:opacity-70 transition-opacity">Read Case Study</a>
            </div>
            <div class="aspect-video bg-ash-veil/10 flex items-center justify-center" style="border-radius: 17.6px;">
              <svg class="w-16 h-16 text-iron-gray/50" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
