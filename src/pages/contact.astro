---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label">Contact</p>
        <h1 class="section-title-main section-title-main-lg">Get in Touch</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl mx-auto">Free consultation. No obligation. Just great conversation.</p>
    </div>
  </section>

  <section class="section-gap bg-carbon-canvas">
    <div class="page-container max-w-4xl mx-auto">
      <div class="grid md:grid-cols-2 gap-12">
        <div>
          <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-6">Let's Talk</h2>
          <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke leading-body-sm mb-8">Fill in the form and we will get back to you within 24 hours.</p>
          <div class="space-y-6">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-bone-white flex items-center justify-center shrink-0" style="border-radius: 9999px;">
                <svg class="w-5 h-5 text-carbon-canvas" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <p class="font-circularxx font-medium text-caption tracking-caption text-bone-white">Email</p>
                <a href="mailto:hello@uroo.dev" class="font-circularxx font-regular text-caption tracking-caption text-smoke hover:text-bone-white transition-colors no-underline">hello@uroo.dev</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-bone-white flex items-center justify-center shrink-0" style="border-radius: 9999px;">
                <svg class="w-5 h-5 text-carbon-canvas" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <p class="font-circularxx font-medium text-caption tracking-caption text-bone-white">WhatsApp</p>
                <a href="https://wa.me/6281234567890" class="font-circularxx font-regular text-caption tracking-caption text-smoke hover:text-bone-white transition-colors no-underline">+62 812-3456-7890</a>
              </div>
            </div>
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 bg-bone-white flex items-center justify-center shrink-0" style="border-radius: 9999px;">
                <svg class="w-5 h-5 text-carbon-canvas" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/></svg>
              </div>
              <div>
                <p class="font-circularxx font-medium text-caption tracking-caption text-bone-white">Location</p>
                <p class="font-circularxx font-regular text-caption tracking-caption text-smoke">Indonesia (Remote)</p>
              </div>
            </div>
          </div>
        </div>
        <div>
          <form class="space-y-5" action="#" method="POST">
            <div>
              <label for="name" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Name</label>
              <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;" placeholder="Your name" />
            </div>
            <div>
              <label for="email" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Email</label>
              <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;" placeholder="your@email.com" />
            </div>
            <div>
              <label for="message" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Message</label>
              <textarea id="message" name="message" rows="5" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke resize-none" style="border-radius: 17.6px;" placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="pill-button font-circularxx w-full justify-center">
              Send Message
            </button>
          </form>
        </div>
      </div>
    </div>
  </section>
</Layout>
