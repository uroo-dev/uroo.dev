---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Get a Free Consultation">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label">Get Started</p>
        <h1 class="section-title-main section-title-main-lg">Get Free Consultation</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl mx-auto">Tell us about your project and we will get back to you within 24 hours.</p>
    </div>
  </section>
  <section class="section-gap bg-carbon-canvas">
    <div class="page-container max-w-2xl mx-auto">
      <form class="space-y-5" action="#" method="POST">
        <div class="grid md:grid-cols-2 gap-5">
          <div>
            <label for="name" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Name</label>
            <input type="text" id="name" name="name" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;" placeholder="Your name" />
          </div>
          <div>
            <label for="email" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Email</label>
            <input type="email" id="email" name="email" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;" placeholder="your@email.com" />
          </div>
        </div>
        <div>
          <label for="company" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Company</label>
          <input type="text" id="company" name="company" class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;" placeholder="Your company name" />
        </div>
        <div>
          <label for="budget" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Budget Range</label>
          <select id="budget" name="budget" class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke" style="border-radius: 17.6px;">
            <option value="">Select a range</option>
            <option value="<1000">Under $1,000</option>
            <option value="1000-3000">$1,000 - $3,000</option>
            <option value="3000-10000">$3,000 - $10,000</option>
            <option value=">10000">$10,000+</option>
          </select>
        </div>
        <div>
          <label for="message" class="font-circularxx font-medium text-caption tracking-caption text-bone-white mb-1.5 block">Project Description</label>
          <textarea id="message" name="message" rows="6" required class="w-full px-4 py-3 border border-ash-veil/20 bg-carbon-canvas font-circularxx font-regular text-caption tracking-caption text-bone-white outline-none transition-colors focus:border-smoke resize-none" style="border-radius: 17.6px;" placeholder="Describe your project..."></textarea>
        </div>
        <button type="submit" class="pill-button font-circularxx w-full justify-center">Submit Request</button>
      </form>
    </div>
  </section>
</Layout>
