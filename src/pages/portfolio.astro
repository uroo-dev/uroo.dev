---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Work — Featured Projects">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label">Our Work</p>
        <h1 class="section-title-main section-title-main-lg">Featured Projects</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl mx-auto">Every project is a story of challenges solved and measurable impact delivered.</p>
    </div>
  </section>

  <section class="section-gap bg-ash-veil">
    <div class="page-container">
      <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-6">
        <a href="/portfolio/kasir-dimas" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Kasir Dimas</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Web-based POS system with product management, sales reports, and multi-user support.</p>
        </a>
        <a href="/portfolio/gudangku-native" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Gudangku Native</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Inventory management system with stock tracking and supplier management.</p>
        </a>
        <a href="/portfolio/memories-keeper" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M4 16l4.586-4.586a2 2 0 012.828 0L16 16m-2-2l1.586-1.586a2 2 0 012.828 0L20 14m-6-6h.01M6 20h12a2 2 0 002-2V6a2 2 0 00-2-2H6a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Memories Keeper</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Digital memory sharing platform for preserving moments.</p>
        </a>
        <a href="/portfolio/sistem-absensi" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Sistem Absensi</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Employee attendance tracking system with reporting features.</p>
        </a>
        <a href="/portfolio/analytics-dashboard" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Analytics Dashboard</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Comprehensive data visualization and BI dashboard.</p>
        </a>
        <a href="/portfolio/chat-system" class="showcase-card block group no-underline">
          <div class="aspect-video bg-carbon-canvas flex items-center justify-center mb-4" style="border-radius: 17.6px;">
            <svg class="w-12 h-12 text-iron-gray" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
          </div>
          <h3 class="showcase-card-title font-medium text-carbon-canvas group-hover:opacity-60 transition-opacity">Chat System</h3>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray mt-1">Real-time messaging platform with team collaboration features.</p>
        </a>
      </div>
    </div>
  </section>
</Layout>
