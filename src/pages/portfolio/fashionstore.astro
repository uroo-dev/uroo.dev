---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="FashionStore — Portfolio">
  <section class="pt-32 pb-20 bg-obsidian">
    <div class="page-container">
      <a href="/portfolio" class="inline-flex items-center gap-2 font-switzer text-sm text-fog hover:text-paper-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Portfolio
      </a>
      <span class="font-space-mono text-caption text-slate uppercase tracking-wider">E-Commerce</span>
      <h1 class="heading-serif-light text-display md:text-display-xl leading-display-xl mt-4 mb-6">FashionStore</h1>
      <p class="font-switzer font-regular text-body-lg text-fog max-w-xl leading-body-lg">Modern e-commerce platform with seamless shopping experience.</p>
    </div>
  </section>

  <section class="section-gap bg-paper-white">
    <div class="page-container max-w-4xl">
      <div class="aspect-video bg-ink flex items-center justify-center mb-16" style="border-radius: 4px;">
        <svg class="w-40 h-40 text-slate/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z"/></svg>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Tech Stack</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">Next.js, Stripe, Prisma, PostgreSQL</p>
        </div>
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Timeline</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">8 weeks</p>
        </div>
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Role</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">Full Stack Developer + UI Designer</p>
        </div>
      </div>

      <div class="space-y-12">
        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">The Challenge</h2>
          <p class="font-switzer font-regular text-body text-graphite leading-body max-w-2xl">A fashion brand wanted to launch an online store with a premium shopping experience, including product variants, secure payments, and an intuitive admin panel for inventory management.</p>
        </div>

        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">The Solution</h2>
          <p class="font-switzer font-regular text-body text-graphite leading-body max-w-2xl">Built a modern e-commerce platform with server-side rendering, optimized images, secure Stripe payments, and a comprehensive admin dashboard.</p>
        </div>

        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">Key Features</h2>
          <ul class="space-y-3 font-switzer font-regular text-body text-graphite">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Product catalog with variants</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Secure payment via Stripe</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Admin dashboard with analytics</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Inventory management</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Order tracking and notifications</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
