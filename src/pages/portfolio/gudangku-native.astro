---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Gudangku Native — Portfolio">
  <section class="pt-36 pb-20 bg-carbon-canvas">
    <div class="page-container">
      <a href="/portfolio" class="font-circularxx font-regular text-caption tracking-caption text-smoke hover:text-bone-white transition-colors no-underline mb-8 inline-flex items-center gap-2">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Portfolio
      </a>
      <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray uppercase mb-2">Web Application</p>
      <h1 class="font-circularxx font-w450 text-display-lg leading-display-lg tracking-display-lg text-bone-white mb-6">Gudangku Native</h1>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-smoke max-w-xl">Inventory management system for stock tracking, in/out logs, and supplier management.</p>
    </div>
  </section>
  <section class="section-gap bg-carbon-canvas">
    <div class="page-container max-w-4xl">
      <div class="aspect-video bg-ash-veil/10 flex items-center justify-center mb-16" style="border-radius: 17.6px;">
        <svg class="w-40 h-40 text-iron-gray/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>
      </div>
      <div class="grid md:grid-cols-3 gap-5 mb-16">
        <div class="review-card text-center">
          <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray uppercase mb-1">Tech Stack</p>
          <p class="review-card-attribution">Laravel, MySQL, Tailwind CSS</p>
        </div>
        <div class="review-card text-center">
          <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray uppercase mb-1">Timeline</p>
          <p class="review-card-attribution">6 weeks</p>
        </div>
        <div class="review-card text-center">
          <p class="font-circularxx font-medium text-caption tracking-caption text-iron-gray uppercase mb-1">Role</p>
          <p class="review-card-attribution">Full Stack Developer</p>
        </div>
      </div>
      <div class="space-y-12 max-w-3xl">
        <div>
          <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-4">The Challenge</h2>
          <p class="review-card-quote">The client, a product distributor handling hundreds of items daily, relied on manual spreadsheet tracking. Issues included frequent stock discrepancies and delayed shipments.</p>
        </div>
        <div>
          <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-4">The Solution</h2>
          <p class="review-card-quote">Built a comprehensive web-based inventory system with real-time dashboard, barcode scanning, automated notifications, and exportable reports.</p>
        </div>
        <div>
          <h2 class="font-circularxx font-w450 text-heading tracking-heading text-bone-white mb-4">Key Features</h2>
          <ul class="space-y-2 review-card-quote">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-bone-white rounded-full mt-1.5 shrink-0"></span>Real-time stock monitoring dashboard</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-bone-white rounded-full mt-1.5 shrink-0"></span>Automated low-stock notifications</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-bone-white rounded-full mt-1.5 shrink-0"></span>Barcode scanner integration</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-bone-white rounded-full mt-1.5 shrink-0"></span>Multi-user role management</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
