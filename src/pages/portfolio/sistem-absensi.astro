---
import Layout from '../../layouts/Layout.astro';
---

<Layout title="Sistem Absensi — Portfolio">
  <section class="pt-32 pb-20 bg-obsidian">
    <div class="page-container">
      <a href="/portfolio" class="inline-flex items-center gap-2 font-switzer text-sm text-fog hover:text-paper-white transition-colors mb-8">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        Back to Portfolio
      </a>
      <span class="font-space-mono text-caption text-slate uppercase tracking-wider">Web Application</span>
      <h1 class="heading-serif-light text-display md:text-display-xl leading-display-xl mt-4 mb-6">Sistem Absensi</h1>
      <p class="font-switzer font-regular text-body-lg text-fog max-w-xl leading-body-lg">Employee attendance tracking system with reporting and management features.</p>
    </div>
  </section>

  <section class="section-gap bg-paper-white">
    <div class="page-container max-w-4xl">
      <div class="aspect-video bg-ink flex items-center justify-center mb-16" style="border-radius: 4px;">
        <svg class="w-40 h-40 text-slate/30" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
      </div>

      <div class="grid md:grid-cols-3 gap-6 mb-16">
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Tech Stack</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">React, Node.js, PostgreSQL</p>
        </div>
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Timeline</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">4 weeks</p>
        </div>
        <div class="border border-fog p-6 text-center" style="border-radius: 4px;">
          <span class="font-space-mono text-caption text-slate uppercase">Role</span>
          <p class="font-switzer font-regular text-body text-ink mt-2">Full Stack Developer</p>
        </div>
      </div>

      <div class="space-y-12">
        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">The Challenge</h2>
          <p class="font-switzer font-regular text-body text-graphite leading-body max-w-2xl">A growing company needed to replace manual attendance tracking with a digital system that could handle multiple locations, shift schedules, and generate automated reports for payroll.</p>
        </div>

        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">The Solution</h2>
          <p class="font-switzer font-regular text-body text-graphite leading-body max-w-2xl">Developed a web-based attendance system with clock-in/out functionality, location-based verification, shift management, and automated reporting.</p>
        </div>

        <div>
          <h2 class="heading-serif text-heading text-ink mb-4">Key Features</h2>
          <ul class="space-y-3 font-switzer font-regular text-body text-graphite">
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Clock-in/out with GPS verification</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Shift scheduling and management</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Automated attendance reports</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Leave and overtime tracking</li>
            <li class="flex items-start gap-3"><span class="w-1.5 h-1.5 bg-ink rounded-full mt-1.5 shrink-0"></span>Multi-location support</li>
          </ul>
        </div>
      </div>
    </div>
  </section>
</Layout>
