---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Solutions">
  <section class="pt-36 pb-20 bg-ash-veil">
    <div class="page-container text-center">
      <div class="section-title-block">
        <p class="section-title-label text-carbon-canvas">What We Do</p>
        <h1 class="section-title-main section-title-main-lg text-carbon-canvas">Our Solutions</h1>
      </div>
      <p class="font-circularxx font-regular text-body-sm tracking-body-sm text-iron-gray max-w-xl mx-auto">Modern, scalable, and performance-driven solutions for your business.</p>
    </div>
  </section>

  <section class="section-gap bg-ash-veil">
    <div class="page-container">
      <div class="grid md:grid-cols-2 gap-6">
        <div class="showcase-card">
          <div class="w-12 h-12 bg-carbon-canvas flex items-center justify-center mb-5" style="border-radius: 9999px;">
            <svg class="w-6 h-6 text-bone-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>
          </div>
          <h2 class="showcase-card-title font-medium text-carbon-canvas mb-3">Website Development</h2>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray leading-caption mb-5">High-performance company profiles, landing pages, and portals built with modern frameworks. SEO-optimized, mobile-first, and lightning fast.</p>
          <ul class="space-y-2 font-circularxx font-regular text-caption tracking-caption text-iron-gray">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Company Profile Websites</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Landing Pages & Campaign Sites</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Portal & Directory Websites</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>E-commerce & Marketplace</li>
          </ul>
        </div>
        <div class="showcase-card">
          <div class="w-12 h-12 bg-carbon-canvas flex items-center justify-center mb-5" style="border-radius: 9999px;">
            <svg class="w-6 h-6 text-bone-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 6H5a2 2 0 00-2 2v9a2 2 0 002 2h14a2 2 0 002-2V8a2 2 0 00-2-2h-5m-4 0V5a2 2 0 114 0v1m-4 0a2 2 0 104 0m-5 8a2 2 0 100-4 2 2 0 000 4zm0 0c1.306 0 2.417.835 2.83 2M9 14a3.001 3.001 0 00-2.83 2M15 11h3m-3 4h2"/></svg>
          </div>
          <h2 class="showcase-card-title font-medium text-carbon-canvas mb-3">Web Applications</h2>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray leading-caption mb-5">Scalable web applications that streamline your operations. From internal tools to customer-facing platforms.</p>
          <ul class="space-y-2 font-circularxx font-regular text-caption tracking-caption text-iron-gray">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>CRM & ERP Systems</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Inventory Management</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Dashboard & Analytics</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>POS & Booking Systems</li>
          </ul>
        </div>
        <div class="showcase-card">
          <div class="w-12 h-12 bg-carbon-canvas flex items-center justify-center mb-5" style="border-radius: 9999px;">
            <svg class="w-6 h-6 text-bone-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M7 21a4 4 0 01-4-4V5a2 2 0 012-2h4a2 2 0 012 2v12a4 4 0 01-4 4zm0 0h12a2 2 0 002-2v-4a2 2 0 00-2-2h-2.343M11 7.343l1.657-1.657a2 2 0 012.828 0l2.829 2.829a2 2 0 010 2.828l-8.486 8.485M7 17h.01"/></svg>
          </div>
          <h2 class="showcase-card-title font-medium text-carbon-canvas mb-3">UI/UX Design</h2>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray leading-caption mb-5">Intuitive interfaces backed by user research and modern design principles. We create experiences that users love.</p>
          <ul class="space-y-2 font-circularxx font-regular text-caption tracking-caption text-iron-gray">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Wireframes & Prototypes</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Design Systems</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>User Research & Testing</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Brand Identity Integration</li>
          </ul>
        </div>
        <div class="showcase-card">
          <div class="w-12 h-12 bg-carbon-canvas flex items-center justify-center mb-5" style="border-radius: 9999px;">
            <svg class="w-6 h-6 text-bone-white" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15"/></svg>
          </div>
          <h2 class="showcase-card-title font-medium text-carbon-canvas mb-3">Maintenance & Support</h2>
          <p class="font-circularxx font-regular text-caption tracking-caption text-iron-gray leading-caption mb-5">Keep your systems secure, up-to-date, and running at peak performance with our maintenance plans.</p>
          <ul class="space-y-2 font-circularxx font-regular text-caption tracking-caption text-iron-gray">
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Bug Fixes & Updates</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Security Patches</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Performance Monitoring</li>
            <li class="flex items-center gap-2"><span class="w-1.5 h-1.5 bg-carbon-canvas rounded-full"></span>Backup & Recovery</li>
          </ul>
        </div>
      </div>
    </div>
  </section>

  <section class="section-gap bg-carbon-canvas text-center">
    <div class="page-container">
      <p class="section-title-label">Need a Custom Solution?</p>
      <h2 class="section-title-main mb-8">Let's Talk</h2>
      <a href="/contact" class="pill-button">Get Free Consultation</a>
    </div>
  </section>
</Layout>
